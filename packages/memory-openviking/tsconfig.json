{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@proj-airi/server-sdk": [
        "../server-sdk/src/index.ts"
      ],
      "@proj-airi/server-sdk/*": [
        "../server-sdk/src/*"
      ]
    },
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../**/node_modules",
    "../server-shared",
    "../server-sdk"
  ]
}
